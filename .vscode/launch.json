{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Local preview (offline JSON)",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/dev/local-preview-server.js",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Local preview (Google Sheet)",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/dev/local-preview-server.js",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
